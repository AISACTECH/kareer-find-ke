{
  "name": "SavedInstitution",
  "type": "object",
  "properties": {
    "institution_id": {
      "type": "string",
      "description": "Unique identifier for the institution"
    },
    "institution_name": {
      "type": "string"
    },
    "program": {
      "type": "string"
    },
    "career": {
      "type": "string"
    },
    "notes": {
      "type": "string",
      "description": "User notes about this institution"
    }
  },
  "required": [
    "institution_id",
    "institution_name"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}
